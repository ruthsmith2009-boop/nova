# === ARIA Real Estate Agent — Environment Variables ===
# Copy this file to .env and fill in your values

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Tavily (Web Research)
TAVILY_API_KEY=your_tavily_api_key_here

# SendGrid (Email)
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=ruth@yourdomain.com
SENDGRID_FROM_NAME=Ruth Smith | Real Estate

# Google Calendar
GOOGLE_CALENDAR_CREDENTIALS_FILE=credentials.json
GOOGLE_CALENDAR_TOKEN_FILE=token.json
GOOGLE_CALENDAR_ID=primary

# App Settings
APP_SECRET_KEY=change-this-to-a-random-secret-string
DATABASE_URL=sqlite:///./aria_re.db
AGENT_NAME=Ruth Smith
AGENT_LICENSE=your_ca_dre_license_number
BROKER_NAME=Your Brokerage Name
AGENT_PHONE=(408) 555-0100
AGENT_EMAIL=ruthsmith2009@gmail.com

# Optional: OpenAI (for fallback)
OPENAI_API_KEY=

# Market Focus
PRIMARY_MARKET=Santa Clara County, California
