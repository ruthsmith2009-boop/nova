# === NOVA — AI Assistant for Small Business — Environment Variables ===
# Copy this file to .env and fill in your values.
# When cloning NOVA for a new client, see docs/CLONE_CHECKLIST.md.

# ── Identity / branding (shown in the app, emails, and call scripts) ──
BUSINESS_NAME=NOVA
AGENT_NAME=Owner Name
AGENT_LICENSE=
BROKER_NAME=Your Business
AGENT_PHONE=(555) 555-0100
AGENT_EMAIL=owner@example.com
PRIMARY_MARKET=United States (any industry)

# ── Anthropic (Claude — required for all AI features) ──
ANTHROPIC_API_KEY=sk-ant-...

# ── Tavily (web research / lead hunting) ──
TAVILY_API_KEY=tvly-...

# ── SendGrid (email sending) ──
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=owner@example.com
SENDGRID_FROM_NAME=Your Business

# ── Google Workspace (Calendar / Gmail OAuth) ──
GOOGLE_ACCOUNT_EMAIL=owner@example.com
GOOGLE_CALENDAR_CREDENTIALS_FILE=credentials.json
GOOGLE_CALENDAR_TOKEN_FILE=token.json
GOOGLE_CALENDAR_ID=primary

# ── App settings ──
APP_SECRET_KEY=change-this-to-a-random-secret-string
DATABASE_URL=sqlite:///./nova.db

# ── Login wall (set both to require sign-in on the deployed app) ──
APP_USERNAME=
APP_PASSWORD=

# ── AI Calling (Vapi + Twilio) ──
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=
VAPI_ASSISTANT_ID=
# Voice for the AI assistant. With VAPI_VOICE_PROVIDER=vapi use a stock Vapi voice
# name (e.g. Savannah). With VAPI_VOICE_PROVIDER=11labs, VAPI_VOICE is an ElevenLabs
# voice ID — e.g. a voice cloned per client from ~2 min of their audio (with consent).
VAPI_VOICE=Savannah
VAPI_VOICE_PROVIDER=vapi
# The client-facing business number (the Twilio number imported into Vapi), E.164.
NOVA_PHONE_NUMBER=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Shared secret for the Vapi call webhook — set the same value as the
# "Server URL Secret" in your Vapi dashboard so only Vapi can post call results.
VAPI_WEBHOOK_SECRET=

# ── Missed-call text-back (SMS) ──
# flip to true once A2P campaign is approved (texting before carrier approval
# gets messages filtered and can hurt the number's reputation)
SMS_TEXTBACK_ENABLED=false
# Optional custom text-back body — leave blank for the default built from
# BUSINESS_NAME ("Hi, this is the AI assistant for <name> — sorry we missed
# your call! ... Reply STOP to opt out.")
SMS_TEXTBACK_MESSAGE=
# Shared secret for the Twilio inbound-SMS webhook (/sms/incoming?token=...)
SMS_WEBHOOK_TOKEN=

# Public base URL for webhooks (auto-detected on Railway; ngrok URL locally)
PUBLIC_BASE_URL=

# ── Inbound lead webhook (Zapier) shared secret ──
LEADGEN_WEBHOOK_TOKEN=

# ── Optional ──
OPENAI_API_KEY=
APOLLO_API_KEY=

# ── Zoho Mail sync (cold-email mailbox → CRM) ──
# App-specific password from Zoho Accounts → Security → App Passwords (NOT the real password).
ZOHO_EMAIL=
ZOHO_APP_PASSWORD=
